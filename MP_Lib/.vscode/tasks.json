{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build All (Script)",
            "type": "shell",
            "command": "cmd",
            "args": ["/c", "build.bat"],
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "cmd",
            "args": ["/c", "build.bat clean"]
        }
    ]
}
